<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.cinehome.review.mapper.ReviewMapper">

    <!-- Result Map 정의 -->
    <resultMap id="ReviewResultMap" type="ReviewDomain">
        <result property="reviewId" column="review_id"/>
        <result property="movieId" column="movie_id"/>
        <result property="userId" column="user_id"/>
        <result property="reviewTitle" column="review_title"/>
        <result property="reviewContent" column="review_content"/>
        <result property="creDt" column="cre_dt"/>
        <result property="updateDt" column="update_dt"/>
        <result property="rating" column="rating"/>
        <result property="viewCount" column="view_count"/>

        <result property="memberId" column="member_id"/>
    </resultMap>

    <select id="listReviews" resultType="ReviewDomain">
        select r.review_id, r.movie_id, r.review_title, r.review_content,
               r.cre_dt, r.update_dt, r.rating, r.view_count,
               m.member_id
        from review r
                 JOIN member m ON r.user_id = m.user_id
        ORDER BY r.review_id DESC;
    </select>

    <select id="view" resultMap="ReviewResultMap">
        select r.*, member_id
        from review r
                 JOIN member m ON r.user_id = m.user_id
        where r.review_id = #{reviewId}
    </select>
    <delete id="deleteReview" parameterType="MemberDomain">
        delete from review
            where review_id = #{reviewId}
    </delete>

</mapper>
